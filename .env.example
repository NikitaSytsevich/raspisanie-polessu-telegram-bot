# Получите у @BotFather. Не добавляйте реальное значение в Git.
TELEGRAM_BOT_TOKEN=

# 32+ случайных символов: A-Z, a-z, 0-9, _ и -.
TELEGRAM_WEBHOOK_SECRET=

# Публичный адрес самостоятельного проекта Vercel, без завершающего /.
APP_URL=https://your-bot.vercel.app

# Отдельный секрет Vercel Cron, не короче 32 случайных символов.
CRON_SECRET=

# Секрет для проверок изменений, которые запускает Upstash QStash.
CHANGE_CHECK_SECRET=

# При прямом подключении Upstash используйте эти переменные. Интеграция Vercel
# Marketplace добавляет KV_REST_API_URL и KV_REST_API_TOKEN автоматически.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
